<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Мерейтойға шақыру — Құралбай 75 жас</title>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cinzel:wght@400;700;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --gold1: #ffe066;
  --gold2: #c9a227;
  --gold3: #8B5E00;
  --gold4: #5a3e00;
  --bg-dark: #7a5500;
  --bg-mid: #9b7015;
  --cream: #fdf6e0;
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { font-family:'Playfair Display',serif; background:#7a5500; overflow-x:hidden; }

/* ============================================================
   COVER
   ============================================================ */
#cover {
  position: fixed; inset: 0; z-index: 200;
  background: radial-gradient(ellipse at 50% 40%, #a87820 0%, #7a5500 55%, #4a3000 100%);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  cursor: pointer;
  transition: opacity .9s cubic-bezier(.4,0,.2,1), transform .9s cubic-bezier(.4,0,.2,1);
}
#cover.opening {
  opacity: 0; transform: scale(1.08);
  pointer-events: none;
}

/* Diagonal cross lines */
#cover::before {
  content:''; position:absolute; inset:0; pointer-events:none;
  background:
    linear-gradient(45deg,  transparent 49.5%, rgba(0,0,0,.18) 49.5%, rgba(0,0,0,.18) 50.5%, transparent 50.5%),
    linear-gradient(-45deg, transparent 49.5%, rgba(0,0,0,.18) 49.5%, rgba(0,0,0,.18) 50.5%, transparent 50.5%);
}

/* Shimmer sweeping across cover */
#cover::after {
  content:''; position:absolute; inset:0; pointer-events:none;
  background: linear-gradient(105deg, transparent 40%, rgba(255,220,100,.12) 50%, transparent 60%);
  animation: shimmer 4s ease-in-out infinite;
}
@keyframes shimmer { 0%,100%{transform:translateX(-100%)} 50%{transform:translateX(100%)} }

.cover-script {
  font-family:'Great Vibes',cursive;
  font-size: clamp(2rem,7vw,3.8rem);
  color:#fff; letter-spacing:2px; margin-bottom:.6rem;
  text-shadow: 0 2px 20px rgba(255,200,60,.4);
  animation: fadeDown .8s ease both;
}
.cover-caps {
  font-family:'Cinzel',serif; font-size:clamp(.6rem,2.5vw,.95rem);
  color:rgba(255,230,150,.9); letter-spacing:.5em; margin-bottom:3rem;
  animation: fadeDown .8s .15s ease both;
}
@keyframes fadeDown { from{opacity:0;transform:translateY(-16px)} to{opacity:1;transform:none} }

/* WAX SEAL */
.seal-wrap {
  position:relative; width:180px; height:180px;
  animation: float 3s ease-in-out infinite, fadeIn .9s .3s ease both;
}
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
@keyframes fadeIn { from{opacity:0;transform:scale(.85)} to{opacity:1;transform:scale(1)} }

.seal-wrap:hover .seal-svg { filter: drop-shadow(0 10px 28px rgba(0,0,0,.65)) brightness(1.08); }
.seal-wrap:active .seal-svg { transform:scale(.93); }

.seal-svg {
  width:100%; height:100%;
  filter: drop-shadow(0 8px 22px rgba(0,0,0,.55));
  transition: transform .12s ease, filter .2s ease;
}

/* Pulse ring behind seal */
.seal-ring {
  position:absolute; inset:-16px; border-radius:50%;
  border:2px solid rgba(255,200,60,.35);
  animation: pulseRing 2.5s ease-in-out infinite;
}
.seal-ring2 {
  position:absolute; inset:-32px; border-radius:50%;
  border:1.5px solid rgba(255,200,60,.18);
  animation: pulseRing 2.5s .6s ease-in-out infinite;
}
@keyframes pulseRing { 0%,100%{transform:scale(1);opacity:.8} 50%{transform:scale(1.06);opacity:.3} }

.cover-hint {
  margin-top:3.5rem; text-align:center;
  color:rgba(255,230,150,.75); font-size:.88rem; line-height:1.9;
  animation: fadeIn 1s .8s ease both;
}

/* ============================================================
   PARTICLES (floating gold dust on cover)
   ============================================================ */
.particle {
  position:absolute; border-radius:50%;
  background:radial-gradient(circle, rgba(255,215,0,.9) 0%, transparent 70%);
  pointer-events:none; animation: particleFloat linear infinite;
}
@keyframes particleFloat {
  0%   { transform:translateY(0) translateX(0) scale(1); opacity:0; }
  10%  { opacity:1; }
  90%  { opacity:.6; }
  100% { transform:translateY(-100vh) translateX(var(--dx,20px)) scale(.3); opacity:0; }
}

/* ============================================================
   INVITATION BODY
   ============================================================ */
#invitation {
  display:none; min-height:100vh;
  background: linear-gradient(180deg,
    #b8860b 0%, #e8c44a 4%, #fdf6e0 12%,
    #fffbe8 50%, #fdf6e0 88%,
    #e8c44a 96%, #b8860b 100%);
  position:relative; overflow-x:hidden;
}
#invitation.show { display:block; }

/* Glitter particles over invitation */
.glitter {
  position:fixed; width:4px; height:4px; border-radius:50%;
  background:var(--gold1); pointer-events:none; z-index:50;
  animation: glitterFall linear infinite;
}
@keyframes glitterFall {
  0%   { transform:translateY(-10px) rotate(0deg); opacity:1; }
  100% { transform:translateY(100vh) rotate(720deg); opacity:0; }
}

/* ============================================================
   SLIDE-IN ANIMATION for sections
   ============================================================ */
.reveal {
  opacity:0; transform:translateY(40px);
  transition: opacity .7s ease, transform .7s ease;
}
.reveal.visible { opacity:1; transform:none; }

/* ============================================================
   WRAPPER
   ============================================================ */
.inv-wrapper {
  max-width:460px; margin:0 auto; padding:0 14px 60px;
  position:relative; z-index:1;
}

/* ============================================================
   TOP ARCH
   ============================================================ */
.top-arch { text-align:center; padding-top:0; margin-bottom:-8px; }
.top-arch svg { width:min(400px,100%); height:auto; }

/* ============================================================
   INNER CARD
   ============================================================ */
.card {
  background:linear-gradient(180deg,#fdf6df 0%,#fffbe8 45%,#fdf6df 100%);
  border:2px solid var(--gold2);
  box-shadow: 0 0 0 1px #e8c84a, 0 0 0 7px rgba(201,162,39,.12),
              0 8px 40px rgba(0,0,0,.18), inset 0 0 40px rgba(255,220,80,.06);
  border-radius:6px; padding:28px 22px 32px; text-align:center;
  position:relative; overflow:hidden;
}

/* Corner ornaments */
.card::before, .card::after {
  content:'✦'; position:absolute; font-size:1.2rem; color:var(--gold2); opacity:.5;
}
.card::before { top:10px; left:12px; }
.card::after  { top:10px; right:12px; }

/* ============================================================
   TYPOGRAPHY
   ============================================================ */
.divider {
  display:flex; align-items:center; gap:8px;
  margin:10px 0; color:var(--gold2);
}
.divider::before,.divider::after {
  content:''; flex:1; height:1px;
  background:linear-gradient(90deg,transparent,var(--gold2),transparent);
}
.divider-icon { font-size:.95rem; }

.greeting {
  font-family:'Cinzel',serif; font-size:.72rem; color:#7a5c00;
  letter-spacing:.08em; line-height:1.75; margin-bottom:6px;
}
.invite-word {
  font-family:'Great Vibes',cursive; font-size:1.9rem; color:var(--gold4);
  margin:2px 0;
}
.name-gold {
  font-family:'Cinzel',serif; font-weight:900;
  font-size:clamp(1.9rem,8vw,2.7rem);
  background:linear-gradient(180deg,#ffe580 0%,#c9870a 42%,#7a3e00 72%,#c9870a 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  line-height:1.05; letter-spacing:.03em;
  filter:drop-shadow(0 2px 3px rgba(0,0,0,.15));
}
.name-sub { font-family:'Cinzel',serif; font-size:.78rem; color:var(--gold3); letter-spacing:.1em; margin:3px 0 10px; }

.age {
  font-family:'Cinzel',serif; font-weight:900;
  font-size:clamp(3.8rem,16vw,5.5rem);
  background:linear-gradient(180deg,#ffe580 0%,#d4a017 38%,#8B5E00 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  line-height:1; display:block; margin:6px 0 2px;
  filter:drop-shadow(0 3px 5px rgba(0,0,0,.2));
  animation: agePulse 3s ease-in-out infinite;
}
@keyframes agePulse { 0%,100%{filter:drop-shadow(0 3px 5px rgba(0,0,0,.2))} 50%{filter:drop-shadow(0 3px 12px rgba(200,160,0,.5))} }

.age-lbl { font-family:'Playfair Display',serif; font-size:.88rem; color:var(--gold4); margin-bottom:6px; }

.name2 {
  font-family:'Cinzel',serif; font-weight:900;
  font-size:clamp(1.3rem,5.5vw,1.9rem);
  background:linear-gradient(180deg,#ffe580 0%,#c9870a 42%,#7a3e00 72%,#c9870a 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  line-height:1.2; letter-spacing:.02em;
}
.event-txt {
  font-family:'Playfair Display',serif; font-size:.83rem; color:var(--gold4);
  line-height:1.85; margin:8px 0 14px;
}

/* Info row */
.info-row {
  display:flex; align-items:center; justify-content:center;
  gap:18px; flex-wrap:wrap; margin:14px 0;
}
.info-item {
  display:flex; align-items:center; gap:7px;
  font-family:'Cinzel',serif; font-size:.88rem;
  color:var(--gold4); font-weight:700;
}
.info-item svg { width:20px; height:20px; stroke:var(--gold2); flex-shrink:0; }
.sep { width:1px; height:28px; background:var(--gold2); opacity:.6; }

.loc-name { font-family:'Playfair Display',serif; font-size:.82rem; color:var(--gold4); line-height:1.5; }
.loc-hall {
  font-family:'Cinzel',serif; font-weight:700; font-size:.98rem;
  background:linear-gradient(180deg,#e8c84a,#c9870a);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.bot-script { font-family:'Great Vibes',cursive; font-size:1.15rem; color:var(--gold4); line-height:1.7; margin:12px 0 6px; }
.family-name { font-family:'Cinzel',serif; font-size:.83rem; color:var(--gold3); font-weight:700; letter-spacing:.06em; margin-top:6px; }
.small-lbl { font-family:'Playfair Display',serif; font-size:.7rem; color:#7a5c00; margin-bottom:2px; }

/* ============================================================
   RSVP SECTION
   ============================================================ */
.rsvp-section {
  background:linear-gradient(135deg,#fdf3cc 0%,#fffbe0 50%,#fdf3cc 100%);
  border:2px solid var(--gold2);
  border-radius:12px; padding:24px 20px;
  margin-top:18px;
  box-shadow:0 4px 20px rgba(0,0,0,.12), 0 0 0 1px rgba(255,215,0,.2);
}
.rsvp-title {
  font-family:'Cinzel',serif; font-weight:700;
  font-size:1rem; color:var(--gold3);
  letter-spacing:.08em; margin-bottom:4px;
}
.rsvp-sub { font-family:'Playfair Display',serif; font-size:.78rem; color:#7a5c00; margin-bottom:16px; }

.rsvp-buttons { display:flex; gap:10px; justify-content:center; margin-bottom:16px; flex-wrap:wrap; }

.rsvp-btn {
  font-family:'Cinzel',serif; font-size:.78rem; font-weight:700;
  padding:10px 20px; border-radius:30px; border:2px solid var(--gold2);
  cursor:pointer; transition:all .25s ease; letter-spacing:.05em;
  background:transparent; color:var(--gold3);
}
.rsvp-btn:hover { transform:translateY(-2px); box-shadow:0 4px 14px rgba(0,0,0,.15); }
.rsvp-btn.yes  { background:linear-gradient(135deg,#c9a227,#8B5E00); color:#fff; border-color:#c9a227; }
.rsvp-btn.yes:hover  { background:linear-gradient(135deg,#e8c84a,#a07020); box-shadow:0 4px 18px rgba(200,160,0,.4); }
.rsvp-btn.no   { background:linear-gradient(135deg,#d4a0a0,#8b3030); color:#fff; border-color:#c07070; }
.rsvp-btn.no:hover   { background:linear-gradient(135deg,#e8b0b0,#a04040); }
.rsvp-btn.maybe { background:linear-gradient(135deg,#a0b4d4,#305080); color:#fff; border-color:#7090c0; }
.rsvp-btn.maybe:hover { background:linear-gradient(135deg,#b0c8e8,#406090); }

.rsvp-btn.selected { transform:scale(1.08); box-shadow:0 0 0 3px rgba(255,215,0,.5),0 6px 20px rgba(0,0,0,.2); }

.rsvp-name-input {
  width:100%; padding:10px 14px; border-radius:8px;
  border:1.5px solid var(--gold2); background:rgba(255,250,220,.8);
  font-family:'Playfair Display',serif; font-size:.88rem; color:var(--gold4);
  outline:none; margin-bottom:10px;
  transition:border-color .2s, box-shadow .2s;
}
.rsvp-name-input:focus { border-color:#c9870a; box-shadow:0 0 0 3px rgba(200,150,0,.15); }
.rsvp-name-input::placeholder { color:rgba(120,90,0,.4); }

.rsvp-submit {
  width:100%; padding:12px; border-radius:30px;
  background:linear-gradient(135deg,var(--gold1),var(--gold2),var(--gold3));
  border:none; cursor:pointer;
  font-family:'Cinzel',serif; font-size:.85rem; font-weight:700;
  color:#3a1800; letter-spacing:.1em;
  transition:all .25s ease;
  box-shadow:0 4px 16px rgba(0,0,0,.2);
}
.rsvp-submit:hover { transform:translateY(-2px); box-shadow:0 6px 22px rgba(200,150,0,.4); }
.rsvp-submit:active { transform:translateY(0); }

.rsvp-thanks {
  display:none; text-align:center;
  font-family:'Great Vibes',cursive; font-size:1.6rem; color:var(--gold3);
  animation:fadeIn .6s ease;
  padding:10px 0;
}
.rsvp-thanks.show { display:block; }

/* ============================================================
   ADDRESS / MAP SECTION
   ============================================================ */
.address-section {
  background:linear-gradient(135deg,#fdf3cc 0%,#fffbe0 50%,#fdf3cc 100%);
  border:2px solid var(--gold2); border-radius:12px;
  padding:20px 18px; margin-top:14px;
  box-shadow:0 4px 20px rgba(0,0,0,.12);
}
.address-title {
  font-family:'Cinzel',serif; font-weight:700; font-size:.95rem;
  color:var(--gold3); letter-spacing:.07em; margin-bottom:10px;
}
.address-text {
  font-family:'Playfair Display',serif; font-size:.82rem; color:var(--gold4);
  line-height:1.7; margin-bottom:14px;
}
.map-link {
  display:inline-flex; align-items:center; gap:8px;
  background:linear-gradient(135deg,var(--gold1),var(--gold2));
  color:#3a1800; font-family:'Cinzel',serif; font-size:.78rem; font-weight:700;
  padding:10px 22px; border-radius:30px; text-decoration:none;
  letter-spacing:.06em; transition:all .25s ease;
  box-shadow:0 3px 12px rgba(0,0,0,.2);
}
.map-link:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(200,150,0,.4); }
.map-link svg { width:16px; height:16px; }

/* ============================================================
   MUSIC BUTTON
   ============================================================ */
.music-btn {
  position:fixed; bottom:24px; right:20px; z-index:300;
  width:50px; height:50px; border-radius:50%;
  background:linear-gradient(135deg,var(--gold1),var(--gold2));
  border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 18px rgba(0,0,0,.35);
  transition:transform .2s ease, box-shadow .2s ease;
  display:none; /* shown after open */
}
.music-btn:hover { transform:scale(1.1); box-shadow:0 6px 24px rgba(200,150,0,.5); }
.music-btn.playing { animation: musicPulse 1.5s ease-in-out infinite; }
@keyframes musicPulse { 0%,100%{box-shadow:0 4px 18px rgba(0,0,0,.35)} 50%{box-shadow:0 4px 28px rgba(255,200,50,.6)} }
.music-icon { font-size:1.3rem; }

/* ============================================================
   SPARKLE GLITTER on invitation
   ============================================================ */
.spark {
  position:fixed; pointer-events:none; z-index:10;
  border-radius:50%;
  background:radial-gradient(circle,rgba(255,220,60,.85) 0%,transparent 70%);
  animation:sparkFloat ease-in-out infinite;
}
@keyframes sparkFloat {
  0%,100%{opacity:0;transform:scale(.4) translateY(0)} 
  20%{opacity:1} 
  80%{opacity:.7} 
  100%{opacity:0;transform:scale(.2) translateY(-60px)}
}

/* Bottom arch ornament */
.bot-arch { text-align:center; margin-top:8px; }
.bot-arch svg { width:min(340px,90%); }

/* ============================================================
   COUNTDOWN TIMER
   ============================================================ */
.timer-section {
  background:linear-gradient(135deg,#3a1800 0%,#5a2e00 40%,#3a1800 100%);
  border:2px solid var(--gold2);
  border-radius:12px; padding:22px 18px 24px;
  margin-top:14px;
  box-shadow:0 4px 24px rgba(0,0,0,.35), 0 0 0 1px rgba(255,215,0,.15),
             inset 0 1px 0 rgba(255,220,100,.1);
  position:relative; overflow:hidden;
}
.timer-section::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg,rgba(255,210,60,.06) 0%,transparent 60%);
  pointer-events:none;
}
.timer-title {
  font-family:'Cinzel',serif; font-weight:700; font-size:.82rem;
  color:var(--gold1); letter-spacing:.12em; margin-bottom:4px;
  text-transform:uppercase;
}
.timer-sub {
  font-family:'Great Vibes',cursive; font-size:1.1rem;
  color:rgba(255,220,100,.75); margin-bottom:18px;
}
.timer-grid {
  display:flex; justify-content:center; align-items:center;
  gap:6px; flex-wrap:wrap;
}
.timer-block {
  display:flex; flex-direction:column; align-items:center;
  min-width:62px;
}
.timer-num {
  font-family:'Cinzel',serif; font-weight:900;
  font-size:clamp(1.8rem,8vw,2.6rem); line-height:1;
  background:linear-gradient(180deg,#ffe580 0%,#c9a227 55%,#8B5E00 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  min-width:58px; text-align:center;
  padding:10px 6px 8px;
  background-color:rgba(255,200,60,.07);
  border:1px solid rgba(255,200,60,.2);
  border-radius:8px;
  box-shadow:0 2px 12px rgba(0,0,0,.3), inset 0 1px 0 rgba(255,220,100,.08);
  transition:transform .15s ease;
  position:relative;
}
.timer-num.tick {
  animation:numTick .15s ease;
}
@keyframes numTick {
  0%   { transform:translateY(-4px); opacity:.6; }
  100% { transform:translateY(0);    opacity:1; }
}
.timer-lbl {
  font-family:'Cinzel',serif; font-size:.58rem; font-weight:600;
  color:rgba(255,200,60,.6); letter-spacing:.1em;
  margin-top:5px; text-transform:uppercase;
}
.timer-colon {
  font-family:'Cinzel',serif; font-weight:900;
  font-size:clamp(1.4rem,6vw,2rem);
  color:rgba(255,200,60,.5); line-height:1;
  padding-bottom:20px;
  animation:colonBlink 1s ease-in-out infinite;
}
@keyframes colonBlink { 0%,100%{opacity:.5} 50%{opacity:1} }

.timer-event-date {
  font-family:'Playfair Display',serif; font-size:.78rem;
  color:rgba(255,220,100,.55); margin-top:14px; letter-spacing:.05em;
}
.timer-done {
  font-family:'Great Vibes',cursive; font-size:1.8rem;
  color:var(--gold1); padding:10px 0;
  animation: fadeIn .6s ease;
}

/* ============================================================
   ENVELOPE OPEN ANIMATION
   ============================================================ */
@keyframes envelopeOpen {
  0%   { clip-path:inset(100% 0 0 0); opacity:0; transform:translateY(30px); }
  100% { clip-path:inset(0 0 0 0); opacity:1; transform:none; }
}
.env-animate { animation: envelopeOpen .8s cubic-bezier(.4,0,.2,1) both; }

</style>
</head>
<body>

