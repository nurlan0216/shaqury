               C144 184,139 180,133 182 C127 184,124 190,118 191 C112 192,108 187,102 188
               C96 189,93 194,87 194 C81 194,77 189,71 188 C65 187,62 192,56 191
               C50 190,47 184,41 182 C35 180,30 184,25 181 C20 178,19 171,14 167
               C9 163,2 164,-2 159 C-6 154,-3 147,-6 141 C-9 135,-16 134,-18 127
               C-20 120,-14 116,-14 109 C-14 102,-20 101,-22 94 C-24 87,-18 84,-18 77
