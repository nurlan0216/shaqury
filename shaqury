/* ---- Countdown Timer ---- */
(function initTimer(){
  // Target: 28 June 2026 18:00 Almaty (UTC+5)
  const target = new Date('2026-06-28T13:00:00Z'); // 18:00 Almaty = 13:00 UTC

  const els = {
    d: document.getElementById('tDays'),
    h: document.getElementById('tHours'),
    m: document.getElementById('tMins'),
    s: document.getElementById('tSecs')
  };

  let prevVals = {d:'',h:'',m:'',s:''};

  function pad(n){ return String(Math.max(0,n)).padStart(2,'0'); }

  function tick(){
    const now = Date.now();
    const diff = target.getTime() - now;

    if(diff <= 0){
      document.getElementById('timerGrid').innerHTML =
        '<div class="timer-done">Мерейтой басталды! 🎉</div>';
      return;
    }

    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);

    const vals = { d:pad(d), h:pad(h), m:pad(m), s:pad(s) };

    if(vals.s !== prevVals.s){ animateTick(els.s); els.s.textContent = vals.s; }
    if(vals.m !== prevVals.m){ animateTick(els.m); els.m.textContent = vals.m; }
    if(vals.h !== prevVals.h){ animateTick(els.h); els.h.textContent = vals.h; }
    if(vals.d !== prevVals.d){ animateTick(els.d); els.d.textContent = vals.d; }

    prevVals = vals;
  }

  function animateTick(el){
    el.classList.remove('tick');
    void el.offsetWidth; // reflow
    el.classList.add('tick');
  }

  tick();
  setInterval(tick, 1000);
})();

function burstConfetti(){
  for(let i=0;i<30;i++){
    const c = document.createElement('div');
    c.style.cssText=`
      position:fixed; z-index:999; pointer-events:none;
      width:8px; height:8px; border-radius:2px;
      background:${['#ffe066','#c9a227','#fff8e0','#f0c040','#fff'][Math.floor(Math.random()*5)]};
      left:${40+Math.random()*20}%;
      top:60%;
      animation:confettiFly ${Math.random()*.8+.6}s ease-out forwards;
      --dx:${(Math.random()-.5)*200}px;
      --dy:${-(Math.random()*200+100)}px;
      --rot:${Math.random()*720}deg;
    `;
    document.body.appendChild(c);
    setTimeout(()=>c.remove(), 1500);
  }
}

// Add confetti keyframe
const style=document.createElement('style');
style.textContent=`
  @keyframes confettiFly {
    0%   {transform:translate(0,0) rotate(0); opacity:1;}
    100% {transform:translate(var(--dx),var(--dy)) rotate(var(--rot)); opacity:0;}
  }
`;
document.head.appendChild(style);
</script>
