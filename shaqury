          <feDropShadow dx="0" dy="5" stdDeviation="9" flood-color="rgba(0,0,0,.55)"/>
        </filter>
        <!-- Bumpy edge path for wax seal -->
        <clipPath id="sealClip"><circle cx="100" cy="100" r="95"/></clipPath>
      </defs>
