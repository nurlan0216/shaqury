     COVER PAGE
     ============================================================ -->
<div id="cover" onclick="openInvitation()">

  <!-- Floating gold particles -->
  <div id="particles"></div>

  <div class="cover-script">Сіз шақыру алдыңыз.</div>
  <div class="cover-caps">Мерейтойға шақыру</div>

  <div class="seal-wrap">
    <div class="seal-ring"></div>
    <div class="seal-ring2"></div>
