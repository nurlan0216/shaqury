<script>
/* ---- Particles on cover ---- */
const pContainer = document.getElementById('particles');
for(let i=0;i<22;i++){
  const p = document.createElement('div');
  p.className='particle';
  const sz = Math.random()*6+3;
  p.style.cssText=`
    width:${sz}px;height:${sz}px;
    left:${Math.random()*100}%;
    bottom:${-sz}px;
    --dx:${(Math.random()-.5)*80}px;
    animation-duration:${Math.random()*6+5}s;
    animation-delay:${Math.random()*6}s;
    opacity:0;
  `;
  pContainer.appendChild(p);
}

/* ---- Web Audio ambient music ---- */
let audioCtx = null, musicNodes = [], musicPlaying = false;

function createKazakhAmbient(){
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const master = audioCtx.createGain();
  master.gain.value = 0.06;
  master.connect(audioCtx.destination);

  // Dombra-like plucks: pentatonic scale
  const notes = [196, 220, 261.63, 293.66, 329.63, 392, 440, 523.25];
  let t = audioCtx.currentTime;

  function pluck(freq, time, dur=0.8){
    const osc = audioCtx.createOscillator();
    const env = audioCtx.createGain();
    osc.type='triangle';
    osc.frequency.value=freq;
    env.gain.setValueAtTime(0.4, time);
    env.gain.exponentialRampToValueAtTime(0.001, time+dur);
    osc.connect(env); env.connect(master);
    osc.start(time); osc.stop(time+dur+0.1);
    return osc;
  }

  // Ambient drone
  const drone = audioCtx.createOscillator();
  const droneGain = audioCtx.createGain();
  drone.type='sine'; drone.frequency.value=98;
  droneGain.gain.value=0.03;
  drone.connect(droneGain); droneGain.connect(master);
  drone.start();
  musicNodes.push(drone, master, droneGain);

  // Repeating melody pattern
  function schedulePattern(){
    if(!musicPlaying) return;
    const now = audioCtx.currentTime;
    const pattern = [0,2,4,5,7,5,4,2,0,4,7,4];
    pattern.forEach((n,i)=>{
      pluck(notes[n]*(Math.random()>.7?2:1), now+i*0.45, 0.7);
    });
    setTimeout(schedulePattern, pattern.length*450+1000);
  }
  musicPlaying = true;
  schedulePattern();
}

function toggleMusic(){
  const btn = document.getElementById('musicBtn');
  const icon = document.getElementById('musicIcon');
  if(!audioCtx){
    createKazakhAmbient();
    btn.classList.add('playing');
    icon.textContent='♫';
  } else if(musicPlaying){
    musicPlaying=false;
    audioCtx.suspend();
    btn.classList.remove('playing');
    icon.textContent='♪';
  } else {
    musicPlaying=true;
    audioCtx.resume();
    btn.classList.add('playing');
    icon.textContent='♫';
    // restart pattern
    if(audioCtx){
      const master = audioCtx.createGain();
      master.gain.value=0.06;
      master.connect(audioCtx.destination);
      function schedulePattern2(){
        if(!musicPlaying) return;
        const now=audioCtx.currentTime;
        const notes=[196,220,261.63,293.66,329.63,392,440,523.25];
        const pattern=[0,2,4,5,7,5,4,2,0,4,7,4];
        pattern.forEach((n,i)=>{
          const osc=audioCtx.createOscillator();
          const env=audioCtx.createGain();
          osc.type='triangle'; osc.frequency.value=notes[n]*(Math.random()>.7?2:1);
          const t=now+i*0.45;
          env.gain.setValueAtTime(0.4,t);
          env.gain.exponentialRampToValueAtTime(0.001,t+0.7);
          osc.connect(env); env.connect(master);
          osc.start(t); osc.stop(t+0.8);
        });
        setTimeout(schedulePattern2, pattern.length*450+1000);
      }
      schedulePattern2();
    }
  }
}

/* ---- Open invitation ---- */
function openInvitation(){
  const cover = document.getElementById('cover');
  cover.classList.add('opening');

  // Start music automatically
  setTimeout(()=>{
    const btn = document.getElementById('musicBtn');
    btn.style.display='flex';
    createKazakhAmbient();
    btn.classList.add('playing');
    document.getElementById('musicIcon').textContent='♫';
  }, 400);

  setTimeout(()=>{
    cover.style.display='none';
    const inv = document.getElementById('invitation');
    inv.classList.add('show');
    startGlitter();
    observeReveal();
  }, 900);
}

/* ---- Glitter particles ---- */
function startGlitter(){
  const c = document.getElementById('glitterContainer');
  for(let i=0;i<18;i++){
    const g = document.createElement('div');
    g.className='spark';
    const sz = Math.random()*10+5;
